{
  "name": "obsidian-just-calendar",
  "version": "0.2.2",
  "description": "Just a calendar which works with the core plugins.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
