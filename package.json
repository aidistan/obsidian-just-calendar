    "lint": "eslint ."
  },
  "keywords": [],
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "dependencies": {
    "@calendarjs/ce": "^1.0.6",
    "obsidian": "latest"
  }
}
