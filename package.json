{
	"name": "just-calendar",
	"version": "0.1.0",
	"description": "Just a calendar which works with the core plugins",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [],
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/node": "^16.18.126",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"tslib": "2.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "8.56.1"
	},
	"dependencies": {
		"@calendarjs/ce": "^1.0.6",
		"obsidian": "latest"
	}
}
