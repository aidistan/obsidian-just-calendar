    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1"
  },
  "dependencies": {
    "@hotwired/stimulus": "^3.2.2",
    "obsidian": "latest"
  }
}
